DB_HOST=localhost
DB_PORT=3306
DB_NAME=chatbot_db
DB_USER=root
DB_PASS=

# API OmniChannel (FastAPI) — porta do serviço (ex.: 8001)
API_BASE_URL=http://76.13.168.200:8001
# Timeout geral (segundos); alinhar ao Python: timeout=30.0
API_TIMEOUT=30
# POST /bot/start (comunicação com o Bridge pode demorar)
API_BOT_TIMEOUT=30
# GET /bot/qr: limite máx. de segundos na ligação. A SaaS pode usar SSE (stream contínuo);
# o proxy PHP encerra assim que recebe qrcode no corpo; se o servidor só enviar keep-alive sem QR,
# pode subir este valor (ex.: 180). Após timeout, ainda se tenta extrair QR do buffer já recebido.
API_BOT_QR_TIMEOUT=90

# Consola programador sem painel operacional (redireciona para /programador/api após login)
# PROGRAMADOR_EMAILS=outro@empresa.com
PROGRAMADOR_EMAILS=
# Consola programador + acesso normal ao painel (home, contatos, marketing, …) — para testar como utilizador
# PROGRAMADOR_FULL_ACCESS_EMAILS=alex2andre@yahoo.com.br
PROGRAMADOR_FULL_ACCESS_EMAILS=
